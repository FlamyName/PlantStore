@model IEnumerable<PlantStore.ViewModels.ProductsViewModels>
@{

}

@foreach (var products in Model)
{
    <a asp-page="/Cloth/ClothId"
       asp-route-id="@products.Id"
       class="product-card-link"
       target="_blank"
       rel="noopener noreferrer">
        <div class="product-card">
            <div class="product-image">
                <img src="dadadad"
                     alt="dsadad"
                     loading="lazy"
                     onerror="this.src='/images/placeholder.jpg'">
            </div>
            <div class="product-info">
                <h3 class="product-title">dasdad</h3>
                <p class="product-description">asdasdad ₽</p>
            </div>
        </div>
    </a>
}