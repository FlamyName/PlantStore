@page
@model PrivacyModel
@{
    ViewData["Title"] = "Privacy Policy";
}
<div class="container">
    <div class="row mb-3">
        <div class="col">
            <input type="text" id="newItemName" class="form-control" placeholder="Название элемента" />
        </div>
        <div class="col-auto">
            <button id="addItemBtn" class="btn btn-primary" data-ajax="AddItem">Добавить элемент</button>
        </div>
    </div>

    <div class="row">
        <div class="col">
            <div id="itemsList">
                <div class="card mb-2">
                    <div class="card-body d-flex justify-content-between align-items-center">
                        <span>Элемент 1</span>
                        <button class="btn btn-danger btn-sm delete-item" data-ajax="DeleteItem" data-id="1">Удалить</button>
                    </div>
                </div>
                <div class="card mb-2">
                    <div class="card-body d-flex justify-content-between align-items-center">
                        <span>Элемент 2</span>
                        <button class="btn btn-danger btn-sm delete-item" data-ajax="DeleteItem" data-id="2">Удалить</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <script src="~/js/AjaxNotification.js?v=@DateTime.Now.Ticks"></script>
}